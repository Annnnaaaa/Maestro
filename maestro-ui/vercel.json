{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**"
    }
  },
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "dest": "/api/index?__asset=$1"
    },
    {
      "src": "^/(.*\\.(css|js|mjs|png|jpg|jpeg|webp|svg|ico|txt|json|map))$",
      "dest": "/api/index?__file=$1"
    },
    { "src": "^/(.*)$", "dest": "/api/index?__path=$1" }
  ]
}

